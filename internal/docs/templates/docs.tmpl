{{define "docs-ru"}}

<h2 id="generate-workout">Генерация тренировки</h2>

<div class="endpoint">
  <div class="endpoint-header">
    <span class="method method-get">GET</span>
    <span class="path">/generate_workout</span>
  </div>
  <div class="endpoint-desc">
    Генерирует тренировку из 3 уникальных упражнений, соответствующих переданным фильтрам.
    Возвращает тип тренировки, уровень сложности и список выбранных упражнений.
  </div>


  <div class="section">
    <div class="section-title">Query-параметры</div>
    <table>
      <thead>
        <tr>
          <th>Параметр</th>
          <th>Тип</th>
          <th>Обязательный</th>
          <th>Описание</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>muscle_groups[]</code></td>
          <td><code>string[]</code></td>
          <td class="opt">нет</td>
          <td>Фильтр по группам мышц (повторяемый). Пример: <code>?muscle_groups[]=chest&amp;muscle_groups[]=back</code>
          </td>
        </tr>
        <tr>
          <td><code>category</code></td>
          <td><code>string</code></td>
          <td class="opt">нет</td>
          <td>Фильтр по категории упражнения (например, <code>strength</code>, <code>cardio</code>).</td>
        </tr>
        <tr>
          <td><code>difficulty</code></td>
          <td><code>string</code></td>
          <td class="opt">нет</td>
          <td>Фильтр по уровню сложности: <code>beginner</code>, <code>intermediate</code>, <code>advanced</code>.</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="section">
    <div class="section-title">Ответ — 200 OK</div>
    <table>
      <thead>
        <tr>
          <th>Поле</th>
          <th>Тип</th>
          <th>Описание</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>type</code></td>
          <td><code>string</code></td>
          <td>Преобладающий тип тренировки.</td>
        </tr>
        <tr>
          <td><code>difficulty</code></td>
          <td><code>string</code></td>
          <td>Общий уровень сложности.</td>
        </tr>
        <tr>
          <td><code>exercises</code></td>
          <td><code>Exercise[]</code></td>
          <td>Список выбранных упражнений (см. объект ниже).</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="section">
    <div class="section-title">Объект Exercise</div>
    <table>
      <thead>
        <tr>
          <th>Поле</th>
          <th>Тип</th>
          <th>Описание</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>uuid</code></td>
          <td><code>string</code></td>
          <td>Уникальный идентификатор упражнения.</td>
        </tr>
        <tr>
          <td><code>name</code></td>
          <td><code>string</code></td>
          <td>Название упражнения.</td>
        </tr>
        <tr>
          <td><code>description</code></td>
          <td><code>string</code></td>
          <td>Краткое описание упражнения.</td>
        </tr>
        <tr>
          <td><code>muscle_groups</code></td>
          <td><code>string[]</code></td>
          <td>Задействованные группы мышц.</td>
        </tr>
        <tr>
          <td><code>difficulty</code></td>
          <td><code>string</code></td>
          <td>Уровень сложности упражнения.</td>
        </tr>
        <tr>
          <td><code>category</code></td>
          <td><code>string</code></td>
          <td>Категория упражнения.</td>
        </tr>
      </tbody>
    </table>
  </div>

  <pre>{
  "type": "strength",
  "difficulty": "intermediate",
  "exercises": [
    {
      "uuid": "a1b2c3d4-...",
      "name": "Жим лёжа",
      "description": "Жим штанги на горизонтальной скамье.",
      "muscle_groups": ["chest", "triceps"],
      "difficulty": "intermediate",
      "category": "strength"
    }
  ]
}</pre>

  <div class="section">
    <div class="section-title">Коды ошибок</div>
    <table>
      <thead>
        <tr>
          <th>Статус</th>
          <th>Тело</th>
          <th>Причина</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>405</code></td>
          <td>Method is not allowed</td>
          <td>Использован метод, отличный от GET.</td>
        </tr>
        <tr>
          <td><code>500</code></td>
          <td>Error building workout</td>
          <td>Ошибка запроса к провайдеру или нет доступных упражнений.</td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

