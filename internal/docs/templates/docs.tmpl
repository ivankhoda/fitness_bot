{{/* ════════════════════════════════════════════
ENGLISH
════════════════════════════════════════════ */}}
{{define "docs-en"}}

<h2 id="generate-workout">Generate Workout</h2>

<div class="endpoint">
  <div class="endpoint-header">
    <span class="method method-get">GET</span>
    <span class="path">/generate_workout</span>
  </div>
  <div class="endpoint-desc">
    Generates a randomised workout of 3 unique exercises that match the supplied
    filters. Returns the workout type, difficulty, and the full list of selected
    exercises.
  </div>


  <div class="section">
    <div class="section-title">Query Parameters</div>
    <table>
      <thead>
        <tr>
          <th>Parameter</th>
          <th>Type</th>
          <th>Required</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>muscle_groups[]</code></td>
          <td><code>string[]</code></td>
          <td class="opt">optional</td>
          <td>Filter by one or more muscle groups (repeatable). Example:
            <code>?muscle_groups[]=chest&amp;muscle_groups[]=back</code>
          </td>
        </tr>
        <tr>
          <td><code>category</code></td>
          <td><code>string</code></td>
          <td class="opt">optional</td>
          <td>Filter by exercise category (e.g. <code>strength</code>, <code>cardio</code>).</td>
        </tr>
        <tr>
          <td><code>difficulty</code></td>
          <td><code>string</code></td>
          <td class="opt">optional</td>
          <td>Difficulty level: <code>beginner</code>, <code>intermediate</code>, <code>advanced</code>.</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="section">
    <div class="section-title">Response — 200 OK</div>
    <table>
      <thead>
        <tr>
          <th>Field</th>
          <th>Type</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>type</code></td>
          <td><code>string</code></td>
          <td>Dominant workout type derived from selected exercises.</td>
        </tr>
        <tr>
          <td><code>difficulty</code></td>
          <td><code>string</code></td>
          <td>Overall difficulty derived from selected exercises.</td>
        </tr>
        <tr>
          <td><code>exercises</code></td>
          <td><code>Exercise[]</code></td>
          <td>List of selected exercises (see object below).</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="section">
    <div class="section-title">Exercise Object</div>
    <table>
      <thead>
        <tr>
          <th>Field</th>
          <th>Type</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>uuid</code></td>
          <td><code>string</code></td>
          <td>Unique identifier of the exercise.</td>
        </tr>
        <tr>
          <td><code>name</code></td>
          <td><code>string</code></td>
          <td>Human-readable exercise name.</td>
        </tr>
        <tr>
          <td><code>description</code></td>
          <td><code>string</code></td>
          <td>Short description of the exercise.</td>
        </tr>
        <tr>
          <td><code>muscle_groups</code></td>
          <td><code>string[]</code></td>
          <td>Muscle groups targeted by this exercise.</td>
        </tr>
        <tr>
          <td><code>difficulty</code></td>
          <td><code>string</code></td>
          <td>Difficulty level of the exercise.</td>
        </tr>
        <tr>
          <td><code>category</code></td>
          <td><code>string</code></td>
          <td>Category of the exercise (e.g. strength, cardio).</td>
        </tr>
      </tbody>
    </table>
  </div>

  <pre>{
  "type": "strength",
  "difficulty": "intermediate",
  "exercises": [
    {
      "uuid": "a1b2c3d4-...",
      "name": "Bench Press",
      "description": "Barbell chest press on a flat bench.",
      "muscle_groups": ["chest", "triceps"],
      "difficulty": "intermediate",
      "category": "strength"
    }
  ]
}</pre>

  <div class="section">
    <div class="section-title">Error Responses</div>
    <table>
      <thead>
        <tr>
          <th>Status</th>
          <th>Body</th>
          <th>Reason</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>405</code></td>
          <td>Method is not allowed</td>
          <td>Non-GET method used.</td>
        </tr>
        <tr>
          <td><code>500</code></td>
          <td>Error building workout</td>
          <td>Upstream fetch failed or no exercises available.</td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

{{end}}{{/* docs-en */}}
