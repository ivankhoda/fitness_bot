{{define "base"}}
<!doctype html>
<html lang="{{.Lang}}">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{block "title" .}}Планка — API{{end}}</title>
  <link rel="stylesheet" href="/docs/assets/docs.css" />
</head>

<body>
  <header>
    <div>
      <h1>Планка — API</h1>
      <p>{{block "subtitle" .}}REST API reference{{end}}</p>
    </div>
    <nav class="lang-switcher">
      <a href="?lang=en" {{if eq .Lang "en" }} class="active" {{end}}>EN</a>
      <a href="?lang=ru" {{if eq .Lang "ru" }} class="active" {{end}}>RU</a>
    </nav>
  </header>

  <div class="layout">
    <nav class="sidebar">
      <h3>{{block "nav-title" .}}Endpoints{{end}}</h3>
      {{block "nav" .}}{{end}}
    </nav>
    <main>
      {{block "content" .}}{{end}}
    </main>
  </div>

  <footer>Planka &copy; {{.Year}}</footer>
</body>

</html>
{{end}}
